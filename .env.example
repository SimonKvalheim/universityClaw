TELEGRAM_BOT_TOKEN=

# universityClaw config
VAULT_DIR=./vault
UPLOAD_DIR=./upload
DASHBOARD_PORT=3100

# --- LightRAG ---
LIGHTRAG_PORT=9621
LIGHTRAG_LLM_BINDING=ollama
LIGHTRAG_LLM_MODEL=qwen2.5:3b
LIGHTRAG_EMBED_BINDING=ollama
LIGHTRAG_EMBED_MODEL=nomic-embed-text
LIGHTRAG_OLLAMA_HOST=http://localhost:11434

# --- LightRAG Parallelism ---
# Two independent axes — tune based on whether each runs locally or via remote API.
#
# LLM concurrency (entity extraction):
#   Safe to increase when using a remote API (Claude, OpenAI).
#   Total LLM load ≈ MAX_ASYNC × MAX_PARALLEL_INSERT.
LIGHTRAG_MAX_ASYNC=4
LIGHTRAG_MAX_PARALLEL_INSERT=2
#
# Embedding concurrency (vector indexing):
#   Keep at 1 when using local Ollama to avoid OOM/timeouts.
#   Increase to 4-8 if using a remote embedding API.
LIGHTRAG_EMBED_MAX_ASYNC=1
LIGHTRAG_EMBED_BATCH_NUM=4
